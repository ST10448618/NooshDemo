@model NooshApp.ViewModels.MenuViewModel
@{
    ViewData["Title"] = "Menu";
}

<section class="menu-hero">
    <div class="container">
        <p class="section-eyebrow">Our Menu</p>
        <h1 class="menu-hero-title">Everything We Make</h1>
    </div>
</section>

<section class="menu-controls">
    <div class="container">
        <div class="menu-search-wrap">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
            <input type="text" id="menuSearch" class="menu-search-input" placeholder="Search the menu..." />
        </div>

        <div class="menu-filters" id="menuFilters">
            <button class="filter-pill active" data-category="all">All</button>
            @foreach (var category in Model.Categories)
            {
                <button class="filter-pill" data-category="@category">@category</button>
            }
        </div>
    </div>
</section>

<section class="heat-guide-section">
    <div class="container">
        <button class="heat-guide-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#heatGuideCollapse" aria-expanded="false">
            <i class="fa-solid fa-pepper-hot"></i>
            <span>What do the spice levels mean?</span>
            <i class="fa-solid fa-chevron-down heat-guide-chevron"></i>
        </button>

        <div class="collapse" id="heatGuideCollapse">
            <div class="heat-guide-card">
                <div class="heat-guide-row">
                    <span class="spice-indicator">
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-1"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper"></i>
                    </span>
                    <span class="heat-guide-label">Mild</span>
                </div>
                <div class="heat-guide-row">
                    <span class="spice-indicator">
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-2"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-2"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper"></i>
                    </span>
                    <span class="heat-guide-label">Medium</span>
                </div>
                <div class="heat-guide-row">
                    <span class="spice-indicator">
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-3"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-3"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-3"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper"></i>
                    </span>
                    <span class="heat-guide-label">Hot</span>
                </div>
                <div class="heat-guide-row">
                    <span class="spice-indicator">
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-4"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-4"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-4"></i>
                        <i class="fa-solid fa-pepper-hot spice-pepper filled level-4"></i>
                    </span>
                    <span class="heat-guide-label">Extra Hot</span>
                </div>
                <p class="heat-guide-hashtag">#HowDoYouNOOSH?</p>
            </div>
        </div>
    </div>
</section>

<section class="menu-grid-section">
    <div class="container">
        <div class="row g-4" id="menuGrid">
            @foreach (var item in Model.Items)
            {
                <div class="col-6 col-md-4 col-lg-3 menu-grid-item" data-category="@item.Category" data-name="@item.Name.ToLower()">
                    <div class="meal-card">
                        <div class="meal-card-image">
                            <img src="@item.ImageUrl" alt="@item.Name" loading="lazy" onerror="this.onerror=null; this.src='/images/placeholder-food.jpg';" />
                            @if (item.IsPopular)
                            {
                                <span class="badge-popular">Popular</span>
                            }
                        </div>
                        <div class="meal-card-body">
                            <h5 class="meal-name">@item.Name</h5>
                            <p class="meal-description">@item.Description</p>
                            <div class="meal-footer">
                                <span class="meal-price">R@(item.Price.ToString("0.00"))</span>
                            <div class="meal-tags">
                                @if (item.IsVegetarian)
                                {
                                    <i class="fa-solid fa-leaf tag-veg" title="Vegetarian"></i>
                                }
                                <partial name="_AllergenIcons" model="item" />
                            </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <p id="menuNoResults" class="menu-no-results d-none">
            No items match your search. Try a different term or category.
        </p>
    </div>
</section>

@section Scripts {
    <script src="~/js/menu-filter.js"></script>
}