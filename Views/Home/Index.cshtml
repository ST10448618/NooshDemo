@model NooshApp.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <p class="hero-subtitle">Bold Middle Eastern Street Food</p>
                <h1 class="hero-title">NOOSH<span class="brand-dot">.</span></h1>
                <p class="hero-subtitle">#HowDoYouNOOSH?</p>
                <div class="hero-actions">
                    <a asp-controller="Menu" asp-action="Index" class="btn btn-hero-primary">
                        <i class="fa-solid fa-utensils me-2"></i>View Menu
                    </a>
                    <a href="#locations" class="btn btn-hero-secondary">
                        <i class="fa-solid fa-location-dot me-2"></i>Find A Noosh
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image-wrap">
                    <img src="~/images/hero-placeholder.jpg" alt="Fresh shawarma wrap and sides" class="img-fluid" onerror="this.style.display='none'" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="featured-meals py-5">
    <div class="container">
        <div class="section-header text-center mb-5">
            <p class="section-eyebrow">Fan Favourites</p>
            <h2 class="section-title">Featured Meals</h2>
        </div>

        <div class="row g-4">
            @foreach (var meal in Model.FeaturedMeals)
            {
                <div class="col-6 col-md-3">
                    <div class="meal-card">
                        <div class="meal-card-image">
                            <img src="@meal.ImageUrl" alt="@meal.Name" onerror="this.onerror=null; this.src='/images/placeholder-food.jpg';" />
                            @if (meal.IsPopular)
                            {
                                <span class="badge-popular">Popular</span>
                            }
                        </div>
                        <div class="meal-card-body">
                            <h5 class="meal-name">@meal.Name</h5>
                            <p class="meal-description">@meal.Description</p>
                            <div class="meal-footer">
                                <span class="meal-price">R@(meal.Price.ToString("0.00"))</span>
                                <div class="meal-tags">
                                    @if (meal.IsVegetarian)
                                    {
                                        <i class="fa-solid fa-leaf tag-veg" title="Vegetarian"></i>
                                    }
                                    <partial name="_AllergenIcons" model="meal" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
<section class="delivery-section py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <p class="section-eyebrow delivery-eyebrow">Get It Delivered</p>
                <h2 class="delivery-title">Can't Make It In?</h2>
                <p class="delivery-subtitle">
                    Order through your favourite delivery app and get NOOSH delivered straight to your door.
                </p>

                <div class="delivery-buttons">
                    <a href="@Model.UberEatsUrl" target="_blank" rel="noopener" class="delivery-btn delivery-btn-uber">
                        <i class="fa-solid fa-bag-shopping"></i>
                        <span>Order on Uber Eats</span>
                    </a>
                    <a href="@Model.MrDUrl" target="_blank" rel="noopener" class="delivery-btn delivery-btn-mrd">
                        <i class="fa-solid fa-motorcycle"></i>
                        <span>Order on Mr D</span>
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="delivery-visual">
                    <i class="fa-solid fa-motorcycle delivery-visual-icon"></i>
                    <p class="delivery-visual-label">NOOSH Delivers</p>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="locations-section py-5" id="locations">
    <div class="container">
        <div class="section-header text-center mb-5">
            <p class="section-eyebrow">Find A Noosh</p>
            <h2 class="section-title">Our Locations</h2>
        </div>

        <div class="row g-4">
            @foreach (var store in Model.StoreLocations)
            {
                        <div class="col-md-4">
            <div class="store-card">
                <div class="store-map-wrap">
                    <iframe
                        src="@store.MapEmbedUrl"
                        width="100%"
                        height="180"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="strict-origin-when-cross-origin">
                    </iframe>
                </div>

                <div class="store-card-body">
                    <h5 class="store-name">@store.Name</h5>
                    <p class="store-mall"><i class="fa-solid fa-store me-2"></i>@store.MallName</p>
                    <p class="store-address">@store.Address</p>

                    <div class="store-detail">
                        <i class="fa-solid fa-clock"></i>
                        <span>@store.OpeningHours</span>
                    </div>

                    <div class="store-actions">
                        <a href="tel:@store.PhoneNumber" class="store-action-btn">
                            <i class="fa-solid fa-phone"></i> Call
                        </a>
                        <a href="@store.DirectionsUrl" target="_blank" rel="noopener" class="store-action-btn store-action-primary">
                            <i class="fa-solid fa-location-dot"></i> Directions
                        </a>
                    </div>
                </div>
            </div>
        </div>
            }
        </div>
    </div>
</section>