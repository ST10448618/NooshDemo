@{
    ViewData["Title"] = "Charity";
}

<section class="charity-hero">
    <div class="container">
        <p class="section-eyebrow">Giving Back</p>
        <h1 class="menu-hero-title">Noosh Cares</h1>
        <p class="charity-hero-subtitle">
            Bold flavours, bigger heart — see how we're supporting our community.
        </p>
    </div>
</section>

<section class="charity-mission py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <p class="section-eyebrow">Our Mission</p>
                <h2 class="section-title">Feeding More Than Just Appetites</h2>
                <p class="charity-body-text">
                    We believe great food should bring people together — and that includes
                    supporting the community that supports us. A portion of every order
                    contributes toward local initiatives focused on food security, youth
                    development, and community wellbeing.
                </p>
                <p class="charity-body-text">
                    From meal donations to sponsoring local events, Noosh is committed to
                    showing up for our neighbours, not just our customers.
                </p>
            </div>
            <div class="col-lg-6">
                <div class="charity-image-wrap">
                    <img src="~/images/charity/mission.jpg" alt="Community volunteers preparing meals" onerror="this.onerror=null; this.src='/images/placeholder-food.jpg';" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="charity-run py-5">
    <div class="container">
        <div class="row align-items-center g-5 flex-lg-row-reverse">
            <div class="col-lg-6">
                <p class="section-eyebrow">Annual Event</p>
                <h2 class="section-title">The Noosh Charity Run</h2>
                <p class="charity-body-text">
                    Once a year, we lace up alongside our community for the Noosh Charity Run —
                    a fun, family-friendly 5km/10km route through the city, with every entry fee
                    going directly toward our partner charities.
                </p>
                <ul class="charity-fact-list">
                    <li><i class="fa-solid fa-calendar-days"></i> Held annually — date announced closer to the time</li>
                    <li><i class="fa-solid fa-route"></i> 5km and 10km route options</li>
                    <li><i class="fa-solid fa-people-group"></i> Open to all ages and fitness levels</li>
                    <li><i class="fa-solid fa-shirt"></i> Free Noosh event t-shirt for all entrants</li>
                </ul>
            </div>
            <div class="col-lg-6">
                <div class="charity-image-wrap">
                    <img src="~/images/charity/run.jpg" alt="Charity run participants" onerror="this.onerror=null; this.src='/images/placeholder-food.jpg';" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="charity-events py-5">
    <div class="container">
        <div class="section-header text-center mb-5">
            <p class="section-eyebrow">Get Involved</p>
            <h2 class="section-title">Upcoming Events</h2>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="charity-event-card">
                    <i class="fa-solid fa-hand-holding-heart charity-event-icon"></i>
                    <h5>Community Meal Drives</h5>
                    <p>Monthly meal packs prepared and distributed to families in need across our local area.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="charity-event-card">
                    <i class="fa-solid fa-graduation-cap charity-event-icon"></i>
                    <h5>Youth Skills Workshops</h5>
                    <p>Hands-on kitchen and hospitality skills training for local youth, in partnership with community centres.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="charity-event-card">
                    <i class="fa-solid fa-seedling charity-event-icon"></i>
                    <h5>Community Garden Support</h5>
                    <p>Supporting local food gardens that supply fresh produce back into community feeding schemes.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="charity-donate py-5">
    <div class="container">
        <div class="charity-donate-card">
            <i class="fa-solid fa-heart charity-donate-icon"></i>
            <h2>Want To Donate Directly?</h2>
            <p>
                Every contribution — big or small — helps us do more for our community.
                Reach out to our team to find out how you can get involved or contribute directly.
            </p>
            <a asp-controller="Home" asp-action="Contact" class="btn btn-hero-primary">
                <i class="fa-solid fa-envelope me-2"></i>Get In Touch
            </a>
        </div>
    </div>
</section>